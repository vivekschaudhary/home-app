# @vc1023/passkey-2fa — required environment variables.
# Copy the ones you need into your app's .env.local (and your host's env for
# production). Run `npx passkey-2fa check-env` to verify them.

# ─── Supabase (Settings → API) ───
NEXT_PUBLIC_SUPABASE_URL=          # Project URL, e.g. https://abcd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # anon / publishable key
SUPABASE_SERVICE_ROLE_KEY=         # service_role / secret key — SERVER ONLY

# ─── WebAuthn / passkey (your app's domain) ───
# In production these are REQUIRED and validated (origin must be https, and
# WEBAUTHN_RP_ID must equal the origin host). In local dev they default to
# http://localhost:3000 / localhost.
WEBAUTHN_ORIGIN=                   # e.g. https://yourapp.com
WEBAUTHN_RP_ID=                    # e.g. yourapp.com  (registrable domain, no scheme/port)
WEBAUTHN_RP_NAME=                  # display name shown in the passkey prompt, e.g. "Your App"

# ─── AAL2 session token ───
AUTH_MFA_SECRET=                   # HMAC secret for the 2FA session cookie — `openssl rand -hex 32`

# ─── AAL2 session-clock overrides (PREVIEW / DEV / TEST ONLY) ───
# Compress the AAL2 TTL + renewal window so E2E can drive the re-challenge /
# sliding-renewal paths in seconds. HONORED ONLY when VERCEL_ENV != "production"
# (and NODE_ENV != "production"); production ALWAYS ignores these and uses the
# baked-in defaults (TTL 3600s / renewal window 300s). A leaked value in prod
# cannot shorten the second-factor boundary.
#
# FAIL-CLOSED VALIDATION: positive base-10 integers only, in the range
# [1, 3600]. Any other value — empty, non-numeric, decimal, scientific
# notation, negative, zero, or ABOVE the default (which would LENGTHEN the
# boundary) — is ignored and falls back to the secure default. The override can
# only ever SHORTEN the clock, never widen it. The renewal window is also
# clamped to never exceed the effective TTL.
AAL2_TTL_SECONDS=                  # e.g. 30  (default 3600 = 1h; max 3600; preview/dev/test only)
AAL2_RENEWAL_WINDOW_SECONDS=       # e.g. 5   (default 300 = 5m; clamped to TTL; preview/dev/test only)
