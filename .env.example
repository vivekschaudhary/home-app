# Copy to .env.local and fill. NEVER commit real secrets.
# Aggregation OAuth tokens are NOT stored here — they live in Supabase Vault
# (envelope-encrypted). See docs/foundation/architecture.md → PII handling.

# ─── Supabase (Postgres + Auth + Storage + Vault) ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Inngest (durable jobs: aggregation sync, anomaly scans) ───
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Sentry (observability) ───
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ─── Aggregation provider: Plaid (WLT-2) — client creds only; access tokens go to Vault ───
# Plaid issues a SEPARATE secret per environment; PLAID_ENV selects which is used.
PLAID_CLIENT_ID=
PLAID_ENV=sandbox            # sandbox | production
PLAID_SANDBOX_SECRET=
PLAID_PRODUCTION_SECRET=     # only needed when PLAID_ENV=production

# WLT-13 — the internal /admin/metrics instrument panel. Comma-separated
# allow-list of admin emails (AAL2 still required). Unset = nobody can access.
ADMIN_EMAILS=

# WLT-16 — the "since last time" recap on the dashboard. Ships dark; set to
# "true" to surface it (do so after the daily snapshot job has ≥1 cycle so
# net-worth movement has an anchor). Anything other than "true" hides it.
RECAP_ENABLED=

# WLT-27-2 — Manual account entry. Set to "true" to surface the ManualAccountForm
# and enable POST /api/accounts. USD-only manual accounts are safe before WLT-27-1.
MANUAL_ACCOUNTS_ENABLED=

# WLT-27-5 — Multi-currency account isolation and the RegionSwitcher UI. Set to
# "true" ONLY after the WLT-27-1 regression suite passes in production. When off,
# activeCurrency is always 'USD' and no currency switcher renders (no behavior
# change for existing users). Enables non-USD manual account creation (WLT-27-2)
# and per-currency spending surfaces on budget, dashboard, transactions, and recap.
MULTI_CURRENCY_ACCOUNTS_ENABLED=
