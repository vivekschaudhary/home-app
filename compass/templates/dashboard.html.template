<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Compass — <!-- COMPASS-INSERT:project-name --></title>

  <!-- Markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

  <!-- Mermaid diagrams (ERD, dependency graphs, Gantt) -->
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
    mermaid.initialize({ startOnLoad: false, theme: 'default', securityLevel: 'loose' });
    window.__compassMermaid = mermaid;
  </script>

  <style>
    :root {
      --fg: #1a1a1a;
      --fg-muted: #6a6a6a;
      --bg: #fafafa;
      --bg-card: #ffffff;
      --border: #e5e5e5;
      --accent: #2b6cb0;
      --critical: #c53030;
      --high: #dd6b20;
      --medium: #d69e2e;
      --low: #718096;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: var(--fg);
      background: var(--bg);
      margin: 0;
      line-height: 1.5;
    }
    header {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 2rem;
    }
    header h1 { margin: 0 0 .25rem 0; font-size: 1.4rem; }
    header p { margin: 0; color: var(--fg-muted); font-size: .9rem; }
    nav {
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
      display: flex;
      gap: .25rem;
      overflow-x: auto;
    }
    nav button {
      background: none;
      border: none;
      border-bottom: 3px solid transparent;
      padding: .75rem 1rem;
      font-size: .95rem;
      cursor: pointer;
      color: var(--fg-muted);
      font-family: inherit;
    }
    nav button[aria-selected="true"] {
      color: var(--accent);
      border-bottom-color: var(--accent);
      font-weight: 600;
    }
    main { max-width: 1100px; margin: 0 auto; padding: 2rem; }
    section[role="tabpanel"] { display: none; }
    section[role="tabpanel"].active { display: block; }
    .artifact-block {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.5rem 2rem;
      margin-bottom: 1.5rem;
    }
    .artifact-path {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: .8rem;
      color: var(--fg-muted);
      margin-bottom: 1rem;
      padding-bottom: .5rem;
      border-bottom: 1px dashed var(--border);
    }
    .empty-tab {
      text-align: center;
      color: var(--fg-muted);
      padding: 4rem 2rem;
      font-style: italic;
    }
    .rendered :is(h1, h2, h3, h4) { margin-top: 1.5em; margin-bottom: .5em; }
    .rendered h1 { font-size: 1.6rem; }
    .rendered h2 { font-size: 1.3rem; border-bottom: 1px solid var(--border); padding-bottom: .25rem; }
    .rendered h3 { font-size: 1.1rem; }
    .rendered table {
      border-collapse: collapse;
      width: 100%;
      margin: 1rem 0;
      font-size: .9rem;
    }
    .rendered th, .rendered td {
      border: 1px solid var(--border);
      padding: .5rem .75rem;
      text-align: left;
    }
    .rendered th { background: var(--bg); font-weight: 600; }
    .rendered code {
      background: var(--bg);
      padding: .1em .4em;
      border-radius: 3px;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: .9em;
    }
    .rendered pre {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 1rem;
      overflow-x: auto;
    }
    .rendered pre code { background: none; padding: 0; }
    .rendered blockquote {
      border-left: 3px solid var(--accent);
      padding-left: 1rem;
      color: var(--fg-muted);
      margin: 1rem 0;
    }
    /* Finding-severity pill styling (when rendered markdown contains [CRITICAL] etc.) */
    .rendered h3:has(+ * code:contains("Critical")) { color: var(--critical); }
    /* ── Actions tab (v0.3.13 orchestrator entry point) ────────────────── */
    .action-section {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 1.5rem 2rem;
      margin-bottom: 1.5rem;
    }
    .action-section h2 {
      margin-top: 0;
      font-size: 1.1rem;
      color: var(--fg);
      border-bottom: 1px solid var(--border);
      padding-bottom: .5rem;
    }
    .action-section h2:first-child { margin-top: 0; }
    .action-row { margin-bottom: 1rem; }
    .action-row:last-child { margin-bottom: 0; }
    .action-row .label {
      display: block;
      color: var(--fg-muted);
      font-size: .85rem;
      margin-bottom: .35rem;
      text-transform: uppercase;
      letter-spacing: .03em;
    }
    .action-btn {
      display: inline-block;
      background: var(--accent);
      color: white;
      border: none;
      border-radius: 4px;
      padding: .55rem 1rem;
      font-size: .9rem;
      font-family: inherit;
      cursor: pointer;
      margin: .15rem .4rem .15rem 0;
      transition: background .15s ease-out;
    }
    .action-btn:hover { background: #1e4e8a; }
    .action-btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .action-btn.copied { background: #2f855a; }
    .action-btn.failed { background: var(--critical); }
    .action-btn .cmd {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: .82em;
      opacity: .85;
      margin-left: .35rem;
    }
    .action-help {
      color: var(--fg-muted);
      font-size: .85rem;
      margin-top: 1rem;
      font-style: italic;
    }
    .hitl-gate {
      background: #fff8e1;
      border: 1px solid #f0c441;
      border-radius: 4px;
      padding: .75rem 1rem;
      margin-bottom: .5rem;
      font-size: .9rem;
    }
    .hitl-gate:last-child { margin-bottom: 0; }
    .hitl-gate .path {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: .8em;
      color: var(--fg-muted);
      margin-top: .25rem;
    }
    .finance-summary {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: .35rem 1rem;
      font-size: .9rem;
      max-width: 420px;
    }
    .finance-summary .total {
      font-weight: 600;
      border-top: 1px solid var(--border);
      padding-top: .5rem;
      margin-top: .25rem;
    }
    .project-state {
      font-size: .95rem;
      line-height: 1.55;
    }
    .project-state .next-step {
      color: var(--accent);
      font-weight: 600;
    }
    footer {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 1rem 2rem;
      color: var(--fg-muted);
      font-size: .85rem;
      text-align: center;
      border-top: 1px solid var(--border);
    }
  </style>
</head>
<body>
  <header>
    <h1>Compass Dashboard — <!-- COMPASS-INSERT:project-name --></h1>
    <p>Last generated: <strong><!-- COMPASS-INSERT:timestamp --></strong> · Generated by <code>/dashboard</code></p>
  </header>

  <nav role="tablist">
    <button role="tab" data-tab="actions" aria-selected="true">Actions</button>
    <button role="tab" data-tab="foundation">Foundation</button>
    <button role="tab" data-tab="plan">Plan</button>
    <button role="tab" data-tab="portfolio">Portfolio</button>
    <button role="tab" data-tab="scan">Scan</button>
    <button role="tab" data-tab="metrics">Metrics</button>
    <button role="tab" data-tab="status">Status</button>
  </nav>

  <main>
    <!-- ACTIONS (v0.3.13 — dashboard as orchestrator entry point per v0.4 spec target) -->
    <section role="tabpanel" data-tab="actions" class="active">
      <!-- COMPASS-INSERT:actions-block -->
      <!--
        Workflow agent populates this with up to 4 sub-sections:
        1. <div class="action-section project-state"> — one-paragraph project state summary
        2. <div class="action-section"> with <div class="hitl-gate"> entries — pending HITL gates (omit section if none)
        3. <div class="action-section"> with <div class="action-row"> groups — quick-action workflow launchers
           Each launcher: <button class="action-btn" onclick="compassCopy('/workflow-name', this)">Label <span class="cmd">/workflow-name</span></button>
        4. <div class="action-section"> with <div class="finance-summary"> — token-usage rollup (omit if docs/usage/current.json missing)

        Empty project state: emit only section 1 + a single highlighted /setup-product launcher.
        Otherwise: emit all relevant sections.

        State-aware action visibility (recommended grouping):
        - Create or refine a bet:  /create-brief, /create-bet-architecture, /create-story
        - Build & ship:            /build, /fix, /triage, /ops
        - Observe & report:        /status, /scan, /plan, /metrics
        - Bootstrap (only when foundation incomplete): /setup-product, /setup-foundation-architecture, /create-bet-portfolio
      -->
    </section>

    <!-- FOUNDATION -->
    <section role="tabpanel" data-tab="foundation">
      <!-- COMPASS-INSERT:foundation-blocks -->
      <!--
        For each existing foundation artifact, emit:
        <article class="artifact-block">
          <div class="artifact-path">docs/foundation/product.md</div>
          <script type="text/markdown" data-artifact="docs/foundation/product.md">
            <!-- markdown content inlined verbatim -->
          </script>
          <div class="rendered"></div>
        </article>

        If none exist, emit <div class="empty-tab">Foundation not yet generated. Run /setup-product.</div>
      -->
    </section>

    <!-- PLAN -->
    <section role="tabpanel" data-tab="plan">
      <!-- COMPASS-INSERT:plan-block -->
      <!-- If docs/foundation/plan.md exists, inline it here. Otherwise empty-tab message pointing to /plan. -->
    </section>

    <!-- PORTFOLIO -->
    <section role="tabpanel" data-tab="portfolio">
      <!-- COMPASS-INSERT:portfolio-block -->
      <!-- If docs/foundation/portfolio.md exists, inline it here. Otherwise empty-tab message pointing to /create-bet-portfolio. -->
    </section>

    <!-- SCAN -->
    <section role="tabpanel" data-tab="scan">
      <!-- COMPASS-INSERT:scan-blocks -->
      <!--
        For each bet that has a scan-report.md, emit one artifact-block.
        Group by bet ID with the bet title in a sub-heading.
        If none exist, emit empty-tab message pointing to /scan.
      -->
    </section>

    <!-- METRICS -->
    <section role="tabpanel" data-tab="metrics">
      <!-- COMPASS-INSERT:metrics-blocks -->
      <!--
        Inline the most recent metrics snapshot per bet (latest by date in filename).
        If none exist, emit empty-tab message pointing to /metrics.
      -->
    </section>

    <!-- STATUS -->
    <section role="tabpanel" data-tab="status">
      <!-- COMPASS-INSERT:status-block -->
      <!-- If docs/status.md exists, inline it here. Otherwise empty-tab message pointing to /status. -->
    </section>
  </main>

  <footer>
    <p>This dashboard is a living artifact. Re-run <code>/dashboard</code> after editing markdown directly, or rely on auto-refresh from <code>/scan</code>, <code>/metrics</code>, <code>/plan</code>, <code>/status</code>, <code>/advance</code>.</p>
  </footer>

  <script>
    // Tab switching
    const tabs = document.querySelectorAll('[role="tab"]');
    const panels = document.querySelectorAll('[role="tabpanel"]');
    function activateTab(name) {
      tabs.forEach(t => t.setAttribute('aria-selected', t.dataset.tab === name ? 'true' : 'false'));
      panels.forEach(p => p.classList.toggle('active', p.dataset.tab === name));
      renderPanel(name);
    }
    tabs.forEach(t => t.addEventListener('click', () => activateTab(t.dataset.tab)));

    // Render markdown blocks within a panel (idempotent — only renders unrendered blocks)
    const renderedSet = new WeakSet();
    async function renderPanel(name) {
      const panel = document.querySelector(`[role="tabpanel"][data-tab="${name}"]`);
      if (!panel) return;
      const blocks = panel.querySelectorAll('script[type="text/markdown"]');
      for (const block of blocks) {
        if (renderedSet.has(block)) continue;
        const md = block.textContent;
        const target = block.nextElementSibling;
        if (target && target.classList.contains('rendered')) {
          target.innerHTML = window.marked.parse(md);
          renderedSet.add(block);
        }
      }
      // Render mermaid diagrams within this panel
      if (window.__compassMermaid) {
        const mermaidBlocks = panel.querySelectorAll('pre > code.language-mermaid');
        for (const code of mermaidBlocks) {
          if (code.dataset.processed) continue;
          const pre = code.parentElement;
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid';
          wrapper.textContent = code.textContent;
          pre.replaceWith(wrapper);
          code.dataset.processed = 'true';
        }
        await window.__compassMermaid.run({ querySelector: '[role="tabpanel"].active .mermaid' });
      }
    }

    // ── Actions tab clipboard-copy (v0.3.13 orchestrator entry point) ───
    // Buttons in the Actions tab use this handler via inline onclick:
    //   <button class="action-btn" onclick="compassCopy('/create-brief', this)">
    // Copies the workflow command to clipboard so user can paste into their
    // preferred web app (ChatGPT, Claude.ai) where a Compass-aware AI runs it.
    // Per v0.3.13 — L1 of v0.4 spec target. L2 (CLI + protocol handler for
    // one-click execution) deferred to v0.3.14.
    async function compassCopy(command, button) {
      const originalText = button.innerHTML;
      try {
        await navigator.clipboard.writeText(command);
        button.classList.add('copied');
        button.textContent = '✓ Copied! Paste into ChatGPT / Claude.ai';
        setTimeout(() => {
          button.classList.remove('copied');
          button.innerHTML = originalText;
        }, 2000);
      } catch (err) {
        console.error('Compass clipboard copy failed:', err);
        button.classList.add('failed');
        button.textContent = '⚠ Copy failed — manually copy: ' + command;
        setTimeout(() => {
          button.classList.remove('failed');
          button.innerHTML = originalText;
        }, 3500);
      }
    }
    window.compassCopy = compassCopy;

    // Initial render
    activateTab('actions');
  </script>
</body>
</html>
