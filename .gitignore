# Compass — gitignored derived artifacts
#
# Rule: gitignore only pure views derived from other tracked files with no
# user-relevant state of their own. The dashboard fits — it's a regenerated
# HTML view of artifacts that already live in git. Suppressions, refinement
# logs, metrics snapshots, etc. stay tracked because they carry user state.

# Derived dashboard view — regenerated by /dashboard on demand.
docs/dashboard.html
# Safety snapshot the framework-sync writes before upgrading — pure backup, no state.
.compass-backups/
# Python bytecode from compass/scripts — derived, never source.
__pycache__/
*.pyc
# Per-machine Claude Code settings (permission allowlist churn) — NOT the skills
# under .claude/skills/, which are tracked Compass workflow surface.
.claude/settings.json
.claude/settings.local.json
# ─── Application scaffold (TS + Vercel + Next.js + Supabase + Inngest) ───
node_modules/
.next/
out/
build/
next-env.d.ts
.env
.env.local
.env*.local
.vercel
*.tsbuildinfo
.DS_Store

# Supabase CLI local state
supabase/.temp/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

